{
  "project": {
    "name": "Стенд тестирования БПЛА",
    "version": "1.0.0",
    "authors": ["Полковников А.В.", "Глазырин К.С."],
    "organization": "Кафедра робототехники и противодействия робототехническим комплексам (системам)"
  },
  
  "connection": {
    "mode": "server",
    "comment": "Режим подключения: 'server' - через Python сервер (рекомендуется), 'direct' - не поддерживается (Arduino использует UDP)",
    
    "arduino_udp": {
      "comment": "Arduino отправляет данные через UDP broadcast",
      "local_port": 8888,
      "broadcast_ip": "192.168.0.255"
    },
    
    "server": {
      "server_ip": "localhost",
      "server_port": 8080,
      "endpoint": "/data"
    }
  },
  
  "arduino": {
    "network": {
      "mac": "DE:AD:BE:EF:FE:01",
      "ip": "192.168.0.177",
      "broadcast_ip": "192.168.0.255",
      "udp_port": 8888,
      "device_id": 1
    },
    
    "pins": {
      "rpm_sensors": {
        "motor_1": 6,
        "motor_2": 7,
        "motor_3": 8,
        "motor_4": 9,
        "description": "Цифровые пины для датчиков оборотов (TCRT5000). Моторы 1-2 используют прерывания, 3-4 - polling"
      },
      
      "temperature_sensors": {
        "motor_1": "A0",
        "motor_2": "A1",
        "motor_3": "A2",
        "motor_4": "A3",
        "description": "Аналоговые пины для термисторов NTC 100k"
      },
      
      "load_cells": {
        "hx711_1_dout": 2,
        "hx711_1_sck": 3,
        "hx711_2_dout": 4,
        "hx711_2_sck": 5,
        "description": "Пины для тензодатчиков HX711"
      },
      
      "accelerometer": {
        "i2c_address": "0x53",
        "sda": "A4",
        "scl": "A5",
        "description": "I2C пины для акселерометра ADXL345"
      },
      
      "microphone": {
        "analog_pin": "A6",
        "description": "Аналоговый пин для микрофона MAX9814"
      },
      
      "ethernet": {
        "cs_pin": 10,
        "description": "Chip Select пин для W5500"
      }
    },
    
    "calibration": {
      "temperature": {
        "steinhart_a": 0.001129148,
        "steinhart_b": 0.000234125,
        "steinhart_c": 0.0000000876741,
        "r_series": 100000,
        "description": "Коэффициенты уравнения Стейнхарта-Харта для NTC"
      },
      
      "load_cells": {
        "scale_1": 1000.0,
        "scale_2": 1000.0,
        "description": "Калибровочные коэффициенты для тензодатчиков HX711"
      },
      
      "rpm": {
        "motors_1_2_mode": "interrupt",
        "motors_3_4_mode": "polling",
        "description": "Моторы 1-2 используют прерывания, 3-4 - опрос состояния"
      },
      
      "data_format": {
        "temp_scale": 100,
        "load_scale": 100,
        "accel_raw": true,
        "sound_shift": 2,
        "description": "Температура и нагрузка умножены на 100, звук сдвинут на 2 бита"
      }
    }
  },
  
  "frontend": {
    "update_interval_ms": 100,
    "max_chart_points": 100,
    "theme": {
      "primary_color": "#92000a",
      "secondary_color": "#6b0f1a",
      "background_gradient_start": "#92000a",
      "background_gradient_end": "#5c0011"
    }
  },
  
  "backend": {
    "uart": {
      "baudrate": 115200,
      "timeout": 1,
      "enabled": true
    },
    
    "udp": {
      "port": 8888,
      "enabled": true
    },
    
    "http": {
      "host": "0.0.0.0",
      "port": 8080,
      "enabled": true
    },
    
    "intervals": {
      "uart_ms": 200,
      "udp_ms": 200,
      "sensor_read_ms": 50
    }
  }
}
